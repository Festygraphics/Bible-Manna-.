# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The API URL of your Supabase relational database project
SUPABASE_URL="https://your-supabase-project.supabase.co"

# SUPABASE_ANON_KEY: The public anonymous key for accessing your Supabase client endpoints
SUPABASE_ANON_KEY="your-supabase-anon-key-placeholder"

# TELEGRAM_BOT_TOKEN: The Bot token supplied by @BotFather for processing native Telegram Stars payments.
TELEGRAM_BOT_TOKEN="8788816581:AAHLy2ou9EnoKo19nFgz7FcszvLH5FJEtR0"

# TELEGRAM_WEBHOOK_SECRET: Secret token to authenticate that updates are securely posted by Telegram.
TELEGRAM_WEBHOOK_SECRET="your-telegram-webhook-secret-of-choice"

# TON_RECEIVER_ADDRESS: Configurable TON Wallet receiver address (User friendly bounceable/non-bounceable or raw)
TON_RECEIVER_ADDRESS="UQALg6xZbeD8_nwhC8YwK1C4v8L9Y6mYm2F_0Oas4k2F_6O8"
